// prisma/schema.prisma

// 1. Client Generator
generator client {
  provider = "prisma-client-js"
}

// 2. Database Connection
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 3. The Deck Model
model Deck {
  id        String   @id @default(cuid())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationship: A deck contains many cards
  cards     Card[]   
}

// 4. The Card Model
model Card {
  id             String   @id @default(cuid())
  deckId         String
  front          String   @db.Text
  back           String   @db.Text
  
  // --- SM-2 Algorithm Fields ---
  interval       Int      @default(0)     // Days until this card should be shown again
  repetition     Int      @default(0)     // Consecutive times answered correctly
  easinessFactor Float    @default(2.5)   // Multiplier for how quickly the interval grows
  nextReviewDate DateTime @default(now()) // Timestamp for the exact next review
  
  // Timestamps
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relationship: Links this card to a specific Deck. 
  // onDelete: Cascade means if the Deck is deleted, all its cards are deleted too.
  deck           Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
}
